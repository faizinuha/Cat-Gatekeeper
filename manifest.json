{
   "action": {
      "default_icon": {
         "16": "assets/nekoicon16.png",
         "48": "assets/nekoicon48.png"
      },
      "default_popup": "popup.html",
      "default_title": "__MSG_appName__"
   },
   "content_scripts": [
      {
         "css": [
            "content.css"
         ],
         "js": [
            "content.js"
         ],
         "matches": [
            "<all_urls>"
         ]
      }
   ],
   "default_locale": "en",
   "description": "__MSG_appDescription__",
   "icons": {
      "128": "assets/nekoicon128.png",
      "16": "assets/nekoicon16.png",
      "48": "assets/nekoicon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_appName__",
   "permissions": [
      "storage"
   ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0",
   "web_accessible_resources": [
      {
         "matches": [
            "<all_urls>"
         ],
         "resources": [
            "assets/*"
         ]
      }
   ]
}